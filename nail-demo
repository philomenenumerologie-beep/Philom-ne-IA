    <div>
      <div class="lbl">Occasions</div>
      <div class="em-wrap">
        <div class="em" onclick="this.classList.toggle('sel')">Mariage</div>
        <div class="em" onclick="this.classList.toggle('sel')">Quotidien</div>
        <div class="em" onclick="this.classList.toggle('sel')">Soirée</div>
        <div class="em" onclick="this.classList.toggle('sel')">Professionnel</div>
