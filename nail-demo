        <div class="sz" onclick="selSz(this)">Courte<small>naturel</small></div>
        <div class="sz" onclick="selSz(this)">Moyenne<small>classique</small></div>
        <div class="sz" onclick="selSz(this)">Longue<small>statement</small></div>
