    <div class="df-title">Devis express<em>votre projet en quelques clics</em></div>
    <div>
      <div class="lbl">Type de pose</div>
      <select class="df-select" id="df-style">
        <option value="">Sélectionnez...</option>
        <option>Pose en gel</option>
        <option>Pose en acrylique</option>
        <option>Semi-permanent</option>
        <option>Remplissage gel</option>
        <option>Manucure simple</option>
        <option>French manucure</option>
        <option>Nail art (motifs)</option>
        <option>3D & Décorations</option>
      </select>
    </div>
    <div>
      <div class="lbl">Longueur souhaitée</div>
