    <a class="mbox-wa" id="mbox-wa" href="#" target="_blank">📱 Je veux ce modèle !</a>
    <button class="mbox-cancel" onclick="fermerModal()">Annuler</button>
  </div>
</div>

<script>
var WA = "33600000000";
var API = "https://philo-backend-by2c.onrender.com";

// Données galerie
var MODELES = [
  {id:1, nom:"Baby Boomer", cat:"french", emoji:"🤍", badge:"Best-seller", prix:"XX€", desc:"Dégradé nude-blanc effet naturel et lumineux. Élégant en toutes circonstances."},
  {id:2, nom:"Nude Glazed", cat:"nude", emoji:"✨", badge:"Tendance", prix:"XX€", desc:"Teinte nude avec effet miroir vitrifié. La sophistication à son maximum."},
  {id:3, nom:"Floral Spring", cat:"nail-art", emoji:"🌸", badge:"Nail art", prix:"XX€", desc:"Motifs floraux peints à la main sur fond rose poudré. Doux et romantique."},
  {id:4, nom:"Red Power", cat:"gel", emoji:"💄", badge:"Classique", prix:"XX€", desc:"Rouge profond en gel longue durée. Iconique et intemporel."},
  {id:5, nom:"Chrome Silver", cat:"gel", emoji:"🪞", badge:"Nouveau", prix:"XX€", desc:"Finition chromée argentée ultra-brillante. Effet miroir saisissant."},
  {id:6, nom:"Crystal 3D", cat:"3d", emoji:"💎", badge:"3D", prix:"XX€", desc:"Cristaux Swarovski posés sur gel rosé. Précieux et unique."},
  {id:7, nom:"French Classique", cat:"french", emoji:"🌿", badge:"Indémodable", prix:"XX€", desc:"French manucure traditionnelle pointe blanche nette. Propre et élégant."},
  {id:8, nom:"Marble Luxe", cat:"nail-art", emoji:"🗿", badge:"Nail art", prix:"XX€", desc:"Effet marbre blanc et or réalisé à la main. Luxueux et artistique."},
  {id:9, nom:"Piercing Ongle", cat:"3d", emoji:"🔗", badge:"Piercing", prix:"XX€", desc:"Anneau or ou argent sur ongle gel. Tendance et personnalisable."},
  {id:10, nom:"Milky Nude", cat:"nude", emoji:"🥛", badge:"Doux", prix:"XX€", desc:"Beige laiteux translucide, effet peau nue sublimée. Quotidien chic."},
];

var catActuelle = "tous";

function renderGalerie(){
  var grid = document.getElementById("g-grid");
  grid.innerHTML = "";
  var liste = catActuelle === "tous" ? MODELES : MODELES.filter(function(m){ return m.cat === catActuelle; });
  liste.forEach(function(m){
    var card = document.createElement("div");
    card.className = "g-card";
    card.onclick = function(){ ouvrirModele(m); };
    card.innerHTML = '<div class="g-thumb"><div class="g-thumb-inner">'+m.emoji+'</div><div class="g-badge">'+m.badge+'</div></div><div class="g-info"><div class="g-name">'+m.nom+'</div><div class="g-price"><b>'+m.prix+'</b></div></div>';
    grid.appendChild(card);
  });
}

function filtrer(btn, cat){
  document.querySelectorAll(".gf").forEach(function(b){ b.classList.remove("active"); });
  btn.classList.add("active");
  catActuelle = cat;
  renderGalerie();
}

function ouvrirModele(m){
  document.getElementById("mbox-ico").textContent = m.emoji;
  document.getElementById("mbox-name").textContent = m.nom;
  document.getElementById("mbox-price").innerHTML = "<b>"+m.prix+"</b>";
  document.getElementById("mbox-desc").textContent = m.desc;
  var msg = "Bonjour ! Je suis intéressée par le modèle « "+m.nom+" » ("+m.prix+"). Je voudrais prendre rendez-vous !";
  document.getElementById("mbox-wa").href = "https://wa.me/"+WA+"?text="+encodeURIComponent(msg);
  document.getElementById("overlay").classList.add("open");
}

function fermerModal(){ document.getElementById("overlay").classList.remove("open"); }

// TABS
function showTab(btn, n){
  document.querySelectorAll(".page").forEach(function(p){ p.classList.remove("active"); });
  document.querySelectorAll(".tab").forEach(function(t){ t.classList.remove("active"); });
  document.getElementById("page-"+n).classList.add("active");
  btn.classList.add("active");
  if(n === "galerie") renderGalerie();
}

// CHAT
var SYS = "Tu es l'assistante IA de Luna Nails, un salon de nail art et beauté. Tu réponds en français, avec une voix chaleureuse, douce et professionnelle. Tu aides les clientes avec les tarifs (affichés en 'XX€' car c'est une démo), les soins, les styles, la durée des poses, les retouches, les rendez-vous. Pour tout rendez-vous ou réservation concrète, tu invites à contacter le salon via WhatsApp. Ne mentionne jamais que tu es une IA de démonstration dans tes réponses.";
var busy = false;

function scrollChat(){ setTimeout(function(){ var c=document.getElementById("page-chat"); c.scrollTop=c.scrollHeight; },80); }

function mkAv(){
  var av=document.createElement("div");
  av.className="bav";
  av.innerHTML='<svg viewBox="0 0 24 24" fill="none"><path d="M12 22C12 22 4 16 4 9C4 6 6.5 4 9.5 4C11 4 12 5 12 5C12 5 13 4 14.5 4C17.5 4 20 6 20 9C20 16 12 22 12 22Z" fill="#E8C4BB"/></svg>';
  return av;
}

function addBot(txt, withQ){
  var msgs=document.getElementById("messages");
  var row=document.createElement("div"); row.className="mrow bot";
  var bub=document.createElement("div"); bub.className="bub bot"; bub.textContent=txt;
  if(withQ){
    var qw=document.createElement("div"); qw.className="qbtns";
    [["Tarifs","Quels sont les tarifs ?"],["Styles","Quels styles proposez-vous ?"],["Durée","Combien de temps dure une pose ?"],["Soins","Comment prendre soin de mes ongles en gel ?"],["RDV","Comment prendre rendez-vous ?"]].forEach(function(it){
      var b=document.createElement("button"); b.className="qb"; b.textContent=it[0];
      (function(m){ b.onclick=function(){ send(m); }; })(it[1]);
      qw.appendChild(b);
    });
    bub.appendChild(qw);
  }
  row.appendChild(mkAv()); row.appendChild(bub); msgs.appendChild(row); scrollChat();
}

function setTyping(on){
  var old=document.getElementById("ty-row"); if(old) old.remove();
  if(!on) return;
  var msgs=document.getElementById("messages");
  var row=document.createElement("div"); row.className="mrow bot"; row.id="ty-row";
  var ty=document.createElement("div"); ty.className="tybub";
  ty.innerHTML="<span></span><span></span><span></span>";
  row.appendChild(mkAv()); row.appendChild(ty); msgs.appendChild(row); scrollChat();
}

function send(txt){
  if(!txt||busy) return;
  document.querySelectorAll(".page").forEach(function(p){ p.classList.remove("active"); });
  document.querySelectorAll(".tab").forEach(function(t){ t.classList.remove("active"); });
  document.getElementById("page-chat").classList.add("active");
  document.querySelector(".tab").classList.add("active");
  var msgs=document.getElementById("messages");
  var row=document.createElement("div"); row.className="mrow user";
  var bub=document.createElement("div"); bub.className="bub user"; bub.textContent=txt;
  row.appendChild(bub); msgs.appendChild(row); scrollChat();
  busy=true; setTyping(true);
  fetch(API+"/vitrine",{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({message:txt,userId:"luna_"+Date.now(),systemPrompt:SYS})
  }).then(function(r){ return r.json(); })
  .then(function(d){
    setTyping(false);
    var ans=(d&&d.answer)?d.answer:"Je suis là pour vous aider !";
    var row2=document.createElement("div"); row2.className="mrow bot";
    var bub2=document.createElement("div"); bub2.className="bub bot"; bub2.textContent=ans;
    var low=txt.toLowerCase();
    if(low.indexOf("rdv")>=0||low.indexOf("rendez")>=0||low.indexOf("reserver")>=0||low.indexOf("réserver")>=0){
      var wa=document.createElement("a"); wa.className="wa-btn";
      wa.href="https://wa.me/"+WA+"?text="+encodeURIComponent("Bonjour ! Je voudrais prendre rendez-vous 🌸");
      wa.target="_blank"; wa.textContent="📱 Contacter le salon sur WhatsApp";
      bub2.appendChild(wa);
    }
    row2.appendChild(mkAv()); row2.appendChild(bub2); msgs.appendChild(row2); scrollChat();
    busy=false;
  }).catch(function(){
    setTyping(false); addBot("Petite erreur de connexion, réessayez dans un instant 🌸"); busy=false;
  });
}

function sendMsg(){
  var inp=document.getElementById("inp");
  var txt=inp.value.trim(); if(!txt) return;
  inp.value=""; send(txt);
}

document.getElementById("inp").addEventListener("keydown",function(e){ if(e.key==="Enter") sendMsg(); });

function selSz(el){
  document.querySelectorAll(".sz").forEach(function(e){ e.classList.remove("sel"); });
  el.classList.add("sel");
}

function genDevis(){
  var style=document.getElementById("df-style").value;
  var desc=document.getElementById("df-desc").value.trim();
  var sz=document.querySelector(".sz.sel");
  var size=sz?sz.childNodes[0].textContent.trim():"";
  var styles=Array.from(document.querySelectorAll("#page-devis .em.sel")).map(function(e){ return e.textContent; }).join(", ");
  if(!style&&!desc&&!styles){ alert("Remplissez au moins le type de pose ou un style"); return; }
  var msg="Bonjour ! Je voudrais un devis.\n\n";
  if(style) msg+="Type de pose : "+style+"\n";
  if(size) msg+="Longueur : "+size+"\n";
  if(styles) msg+="Style : "+styles+"\n";
  if(desc) msg+="Précisions : "+desc+"\n";
  msg+="\n(Photos de référence à suivre si besoin 📸)";
  window.open("https://wa.me/"+WA+"?text="+encodeURIComponent(msg),"_blank");
}

// Splash
setTimeout(function(){
  document.getElementById("msg-banniere").style.display="block";
  document.getElementById("splash").classList.add("gone");
  setTimeout(function(){
    document.getElementById("splash").style.display="none";
    addBot("Bonjour ! 🌸 Je suis l'assistante de Luna Nails.\n\nJe peux vous aider avec les tarifs, les styles disponibles, les soins à domicile ou pour prendre rendez-vous.", true);
  }, 900);
}, 2500);

renderGalerie();
</script>
