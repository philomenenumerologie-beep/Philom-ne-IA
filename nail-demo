<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
<title>Luna Nails — Demo</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden;background:#F7EDE8;font-family:'DM Sans',sans-serif;color:#2a1f1a}

:root{
  --cream:#F7EDE8;
  --rose:#E8C4BB;
  --blush:#D4A098;
  --mauve:#9B6B6B;
  --deep:#2a1f1a;
  --pearl:#FDF5F0;
  --gold:#C9A882;
}

@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes shimmer{0%,100%{opacity:1}50%{opacity:.4}}
@keyframes bounce{0%,80%,100%{transform:translateY(0)}40%{transform:translateY(-5px)}}
@keyframes msgIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
@keyframes splashOut{to{opacity:0;pointer-events:none}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}

/* SPLASH */
#splash{position:fixed;inset:0;z-index:500;background:var(--deep);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0;transition:opacity 1s}
#splash.gone{opacity:0;pointer-events:none}
.sp-nail{width:90px;height:90px;margin-bottom:20px;animation:fadeUp .8s cubic-bezier(.16,1,.3,1) .2s both,float 3s ease-in-out 1s infinite}
.sp-nail svg{width:100%;height:100%}
.sp-name{font-family:'Cormorant Garamond',serif;font-size:38px;font-weight:300;color:var(--cream);letter-spacing:.18em;animation:fadeUp .8s cubic-bezier(.16,1,.3,1) .45s both}
.sp-tag{font-size:9px;letter-spacing:.32em;text-transform:uppercase;color:rgba(247,237,232,.3);margin-top:10px;animation:fadeUp .8s cubic-bezier(.16,1,.3,1) .65s both}
.sp-demo{font-size:10px;letter-spacing:.15em;color:var(--gold);margin-top:22px;border:1px solid rgba(201,168,130,.3);padding:5px 14px;border-radius:20px;animation:fadeUp .8s cubic-bezier(.16,1,.3,1) .85s both}

/* APP */
#app{height:100%;display:flex;flex-direction:column;max-width:480px;margin:0 auto}

/* TOPBAR */
#topbar{background:var(--deep);padding:12px 18px 10px;display:flex;align-items:center;gap:12px;flex-shrink:0}
.tb-av{width:44px;height:44px;border-radius:50%;background:var(--rose);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.tb-av svg{width:22px;height:22px}
.tb-name{font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:400;color:var(--cream);letter-spacing:.08em}
.tb-sub{font-size:9.5px;color:rgba(247,237,232,.38);letter-spacing:.1em;text-transform:uppercase;margin-top:1px}
.tb-dot{width:8px;height:8px;border-radius:50%;background:#A8D5A2;box-shadow:0 0 8px #A8D5A2;animation:shimmer 2.5s infinite;margin-left:auto}
.tb-badge{font-size:8px;background:var(--gold);color:var(--deep);padding:2px 7px;border-radius:10px;margin-left:8px;font-weight:600;letter-spacing:.08em}

/* TABS */
#tabs{background:var(--deep);display:flex;border-bottom:1px solid rgba(247,237,232,.08);flex-shrink:0}
.tab{flex:1;padding:9px 2px 8px;text-align:center;font-size:9px;font-weight:500;letter-spacing:.07em;text-transform:uppercase;color:rgba(247,237,232,.3);border:none;background:none;cursor:pointer;border-bottom:2px solid transparent;transition:all .22s;display:flex;flex-direction:column;align-items:center;gap:3px;font-family:'DM Sans',sans-serif}
.tab span{font-size:15px}
.tab.active{color:var(--rose);border-bottom-color:var(--rose)}

/* BANNIERE */
#msg-banniere{display:none;background:var(--deep);color:var(--gold);padding:9px 16px;font-size:12px;font-weight:500;text-align:center;border-bottom:1px solid rgba(201,168,130,.2);flex-shrink:0;letter-spacing:.04em}

/* PAGES */
.page{flex:1;overflow-y:auto;display:none;flex-direction:column}
.page.active{display:flex}
.page::-webkit-scrollbar{width:0}

/* ---- CHAT ---- */
#page-chat{background:var(--cream)}
#messages{flex:1;padding:16px 14px 6px;display:flex;flex-direction:column;gap:10px}
.mrow{display:flex;animation:msgIn .28s cubic-bezier(.16,1,.3,1)}
.mrow.bot{justify-content:flex-start;gap:8px}
.mrow.user{justify-content:flex-end}
.bav{width:32px;height:32px;border-radius:50%;background:var(--deep);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
.bav svg{width:16px;height:16px}
.bub{max-width:min(78%,320px);padding:11px 14px;font-size:13.5px;line-height:1.65;white-space:pre-wrap;border-radius:20px}
.bub.bot{background:white;color:var(--deep);border-top-left-radius:4px;box-shadow:0 2px 12px rgba(0,0,0,.06)}
.bub.user{background:var(--deep);color:var(--cream);border-top-right-radius:4px}
.qbtns{display:flex;flex-wrap:wrap;gap:6px;margin-top:10px}
.qb{padding:6px 12px;border-radius:20px;border:1.5px solid var(--blush);background:transparent;color:var(--mauve);font-size:11.5px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .18s}
.qb:hover{background:var(--blush);color:white}
.tybub{background:white;border-radius:20px;border-top-left-radius:4px;padding:12px 15px;display:flex;gap:5px;box-shadow:0 2px 12px rgba(0,0,0,.06)}
.tybub span{width:6px;height:6px;border-radius:50%;background:var(--blush);animation:bounce 1.2s infinite}
.tybub span:nth-child(2){animation-delay:.2s}
.tybub span:nth-child(3){animation-delay:.4s}
.wa-btn{display:flex;align-items:center;justify-content:center;gap:8px;background:#25D366;color:white;border-radius:12px;padding:11px;font-weight:600;font-size:13px;font-family:'DM Sans',sans-serif;text-decoration:none;margin-top:10px}
#composer{padding:10px 14px 22px;background:var(--cream);border-top:1px solid rgba(0,0,0,.07);flex-shrink:0}
.crow{display:flex;gap:9px;align-items:center}
#inp{flex:1;padding:11px 16px;border-radius:26px;border:1.5px solid rgba(0,0,0,.12);background:white;font-size:14px;font-family:'DM Sans',sans-serif;outline:none;color:var(--deep)}
#inp::placeholder{color:#c4a9a3}
#inp:focus{border-color:var(--blush)}
#snd{width:45px;height:45px;border-radius:50%;border:none;background:var(--deep);color:var(--cream);font-size:17px;display:flex;align-items:center;justify-content:center;cursor:pointer}

/* ---- GALERIE ---- */
#page-galerie{background:var(--cream);padding:20px 15px 36px;gap:14px}
.g-title{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;line-height:1.1}
.g-title em{font-style:italic;color:var(--blush);font-size:.75em;display:block;font-weight:300}
.g-sub{font-size:12.5px;color:var(--mauve);margin-top:6px;margin-bottom:16px}

/* filtres */
.g-filters{display:flex;gap:7px;overflow-x:auto;padding-bottom:4px;margin-bottom:14px}
.g-filters::-webkit-scrollbar{height:0}
.gf{padding:6px 14px;border-radius:20px;border:1.5px solid var(--rose);background:transparent;color:var(--mauve);font-size:11.5px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;white-space:nowrap;flex-shrink:0;transition:all .18s}
.gf.active{background:var(--deep);color:var(--cream);border-color:var(--deep)}

.g-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.g-card{background:white;border-radius:18px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.06);cursor:pointer;transition:transform .18s}
.g-card:active{transform:scale(.97)}
.g-thumb{width:100%;aspect-ratio:1;position:relative;overflow:hidden}
.g-thumb-inner{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:52px;background:linear-gradient(135deg,var(--pearl),var(--rose))}
.g-badge{position:absolute;top:8px;right:8px;background:rgba(255,255,255,.85);backdrop-filter:blur(4px);border-radius:20px;padding:3px 9px;font-size:9px;font-weight:600;letter-spacing:.07em;color:var(--mauve);text-transform:uppercase}
.g-info{padding:10px 12px 13px}
.g-name{font-family:'Cormorant Garamond',serif;font-size:15px;font-weight:600;line-height:1.2}
.g-price{font-size:11.5px;color:var(--blush);margin-top:3px}
.g-price b{color:var(--deep);font-size:13px}

/* ---- DEVIS ---- */
#page-devis{background:var(--cream);padding:20px 15px 36px;gap:14px}
.df-title{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:300}
.df-title em{font-style:italic;color:var(--blush);display:block;font-size:.78em}
.lbl{font-size:9.5px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:#b89a95;margin-bottom:7px}
.df-select,.df-textarea{width:100%;padding:12px 14px;border-radius:13px;border:1.5px solid rgba(0,0,0,.1);background:white;font-size:14px;font-family:'DM Sans',sans-serif;color:var(--deep);outline:none;-webkit-appearance:none}
.df-select:focus,.df-textarea:focus{border-color:var(--blush)}
.df-textarea{resize:none;height:82px}
.sz-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:7px}
.sz{padding:10px 4px;border-radius:12px;border:1.5px solid rgba(0,0,0,.1);background:white;font-size:12px;font-family:'DM Sans',sans-serif;font-weight:500;text-align:center;cursor:pointer;color:#8a6560;line-height:1.4;transition:all .18s}
.sz small{font-size:10px;color:#c4a9a3;display:block}
.sz.sel{background:var(--deep);color:var(--cream);border-color:var(--deep)}
.em-wrap{display:flex;flex-wrap:wrap;gap:7px}
.em{padding:6px 12px;border-radius:20px;border:1.5px solid rgba(0,0,0,.1);background:white;font-size:12px;font-family:'DM Sans',sans-serif;font-weight:500;cursor:pointer;color:#8a6560;transition:all .18s}
.em.sel{background:var(--deep);color:var(--cream);border-color:var(--deep)}
.df-btn{display:flex;align-items:center;justify-content:center;gap:10px;background:#25D366;color:white;border-radius:14px;padding:15px;font-weight:700;font-size:14px;font-family:'DM Sans',sans-serif;border:none;width:100%;cursor:pointer}

/* ---- TARIFS ---- */
#page-tarifs{background:var(--cream);padding:20px 15px 36px;gap:12px}
.t-h{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;line-height:1.1}
.t-h em{font-style:italic;color:var(--blush);font-size:.75em;display:block}
.t-intro{font-size:13px;color:var(--mauve);line-height:1.6;margin-top:4px}
.t-sec{font-size:9px;font-weight:600;letter-spacing:.25em;text-transform:uppercase;color:#c4a9a3;margin-top:8px;padding-bottom:8px;border-bottom:1px solid rgba(0,0,0,.07)}
.tcard{background:white;border-radius:16px;padding:16px;box-shadow:0 2px 10px rgba(0,0,0,.05)}
.tcard-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px}
.tcard-name{font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:600}
.tcard-sub{font-size:11px;color:#b89a95;margin-top:2px}
.tcard-badge{background:var(--deep);color:var(--cream);font-size:9.5px;font-weight:600;padding:4px 9px;border-radius:20px;flex-shrink:0;margin-left:8px;letter-spacing:.05em}
.tprices{display:grid;grid-template-columns:repeat(3,1fr);gap:6px}
.tpx{background:var(--cream);border-radius:9px;padding:9px 4px;text-align:center}
.tplbl{font-size:8.5px;color:#b89a95;font-weight:500;margin-bottom:3px;letter-spacing:.05em}
.tpval{font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:600}
.tpval.x{color:var(--blush);font-style:italic}
.tbonus{margin-top:9px;font-size:11px;color:#b89a95;text-align:center;font-style:italic}
.tbonus b{color:var(--deep);font-style:normal}
.fcard{background:var(--deep);color:var(--cream);border-radius:15px;padding:15px}
.fcard-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.fcard-name{font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:400;letter-spacing:.05em}
.fcard-price{font-family:'Cormorant Garamond',serif;font-size:24px;color:var(--gold);font-style:italic}
.fcard-price.x{font-size:20px;color:var(--rose)}
.fcard-items{display:flex;flex-direction:column;gap:4px}
.fcard-item{font-size:12px;color:rgba(247,237,232,.5);padding-left:10px}
.fcard-gift{font-size:11px;color:var(--gold);margin-top:9px;font-style:italic}
.twa{display:flex;align-items:center;justify-content:center;gap:10px;background:#25D366;color:white;border-radius:14px;padding:15px;text-decoration:none;font-weight:700;font-size:14px;font-family:'DM Sans',sans-serif;margin-top:6px}

/* OVERLAY */
#overlay{position:fixed;inset:0;z-index:300;background:rgba(42,31,26,.55);display:none;align-items:flex-end;justify-content:center;backdrop-filter:blur(3px)}
#overlay.open{display:flex}
#mbox{background:var(--cream);border-radius:24px 24px 0 0;padding:28px 20px 44px;width:100%;max-width:480px;animation:slideUp .32s cubic-bezier(.16,1,.3,1)}
.mbox-thumb{width:150px;height:150px;border-radius:18px;margin:0 auto 14px;display:flex;align-items:center;justify-content:center;font-size:60px;background:linear-gradient(135deg,var(--pearl),var(--rose))}
.mbox-name{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:600;text-align:center;margin-bottom:4px}
.mbox-price{text-align:center;font-size:15px;color:var(--blush);margin-bottom:6px}
.mbox-price b{color:var(--deep);font-size:19px;font-family:'Cormorant Garamond',serif}
.mbox-desc{text-align:center;font-size:12.5px;color:var(--mauve);margin-bottom:20px;line-height:1.5}
.mbox-wa{display:flex;align-items:center;justify-content:center;gap:9px;background:#25D366;color:white;border-radius:13px;padding:14px;font-weight:700;font-size:14px;font-family:'DM Sans',sans-serif;text-decoration:none;margin-bottom:10px}
.mbox-cancel{display:block;text-align:center;padding:12px;font-size:13.5px;color:#b89a95;cursor:pointer;font-family:'DM Sans',sans-serif;border:none;background:none;width:100%}
</style>
</head>
<body>

<!-- SPLASH -->
<div id="splash">
  <div class="sp-nail">
    <svg viewBox="0 0 80 80" fill="none">
      <ellipse cx="40" cy="52" rx="24" ry="28" fill="#E8C4BB"/>
      <ellipse cx="40" cy="48" rx="20" ry="26" fill="#D4A098"/>
      <ellipse cx="40" cy="44" rx="16" ry="24" fill="#F7EDE8"/>
      <ellipse cx="35" cy="38" rx="4" ry="7" fill="rgba(255,255,255,.35)" transform="rotate(-10 35 38)"/>
    </svg>
  </div>
  <div class="sp-name">LUNA NAILS</div>
  <div class="sp-tag">Nail Art &middot; Beauté &middot; Bien-être</div>
  <div class="sp-demo">✦ Application démo ✦</div>
</div>

<div id="app">
  <!-- TOPBAR -->
  <div id="topbar">
    <div class="tb-av">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M12 22C12 22 4 16 4 9C4 6 6.5 4 9.5 4C11 4 12 5 12 5C12 5 13 4 14.5 4C17.5 4 20 6 20 9C20 16 12 22 12 22Z" fill="#F7EDE8"/>
      </svg>
    </div>
    <div>
      <div class="tb-name">Luna Nails</div>
