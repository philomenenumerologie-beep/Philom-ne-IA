    <div>
      <div class="lbl">Précisions (optionnel)</div>
      <textarea class="df-textarea" id="df-desc" placeholder="Ex: mariage en juin, je veux des fleurs dorées..."></textarea>
    </div>
    <button class="df-btn" onclick="genDevis()">📱 Envoyer sur WhatsApp</button>
  </div>

  <!-- TARIFS -->
  <div id="page-tarifs" class="page">
    <div class="t-h">Tarifs<em>clairs et transparents</em></div>
    <div class="t-intro">Nail art, soins et retouches selon les formules.</div>

    <div class="t-sec">Poses</div>
    <div class="tcard">
      <div class="tcard-top"><div><div class="tcard-name">Pose en gel</div><div class="tcard-sub">Gel classique ou french</div></div><div class="tcard-badge">Mains</div></div>
      <div class="tprices">
        <div class="tpx"><div class="tplbl">Courte</div><div class="tpval x">XX€</div></div>
        <div class="tpx"><div class="tplbl">Moyenne</div><div class="tpval x">XX€</div></div>
        <div class="tpx"><div class="tplbl">Longue</div><div class="tpval x">XX€</div></div>
      </div>
    </div>
    <div class="tcard">
      <div class="tcard-top"><div><div class="tcard-name">Remplissage gel</div><div class="tcard-sub">À partir de 3 semaines</div></div><div class="tcard-badge">Mains</div></div>
      <div class="tprices">
        <div class="tpx" style="grid-column:1/-1"><div class="tplbl">Tarif</div><div class="tpval x">XX — XX€</div></div>
      </div>
